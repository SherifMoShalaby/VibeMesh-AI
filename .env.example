# ── AI engines — configure any subset; the app lists whatever is available ──

# Claude via your Claude Code login: nothing to configure here.
# Just have Claude Code installed and logged in (`claude` → /login).
# NOTE: Anthropic only permits this for personal/local use — a distributed
# product must use API keys (or get approval to offer Claude login).

# Claude via API key (https://console.anthropic.com)
# ANTHROPIC_API_KEY=sk-ant-...
# VIBEMESH_MODEL=claude-opus-4-8

# Kimi K2.6 via your Kimi Code subscription:
# easiest: log in once with the kimi CLI — the server reuses that login.
# Or create an API key in the Kimi Code console and set:
# KIMI_API_KEY=...
# KIMI_BASE_URL=https://api.kimi.com/coding
# KIMI_MODEL=kimi-for-coding

# Local LLM (Ollama or LM Studio, OpenAI-compatible).
# Ollama default below; LM Studio uses http://localhost:1234
# LOCAL_LLM_BASE_URL=http://localhost:11434

# ── Generation tuning (optional) ──
# Reasoning effort for the Claude engines: low | medium | high | xhigh | max (default xhigh).
# VIBEMESH_EFFORT=xhigh
# Output ceiling (max_tokens). Bound to the model: defaults to 64k, CLAMPED to the model's real
# max (Opus 4.8 = 128k, Sonnet/Haiku = 64k). Set this to reach Opus's full 128k output.
# VIBEMESH_MAX_OUTPUT_TOKENS=128000
# Generation request timeout in ms (default 3600000 = 1 h). Bounds BOTH the server request and the
# client anti-hang cap. The 1 h default gives Opus at high/max effort plenty of room; raise it for
# very hard parts (7200000 = 2 h) or lower it to fail faster.
# VIBEMESH_GEN_TIMEOUT_MS=7200000
# Retries on a transient/timeout error (default 1). 0 = never retry (one attempt, then fail).
# VIBEMESH_GEN_MAX_RETRIES=1

# PORT=5175

# ── Supabase — required for server-side auth + DB ──
# Leave ALL four unset to run in local-only mode (no auth gate, no sync).
#
# Option A: Local Docker Supabase  (`docker compose up` → Kong on :8000)
# These are the standard local-dev JWT keys from docker-compose.yml.
# SUPABASE_URL=http://localhost:8000
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hj04zWl196z2-SBc0
# VITE_SUPABASE_URL=http://localhost:8000
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRFA0NiK7urfjjMvpOiFSoNZ5tY6sNbMLnkZ7g7Pq3M
#
# Option B: Supabase Cloud
# Get these from your project → Settings → API
# SUPABASE_URL=https://<project-id>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
# VITE_SUPABASE_URL=https://<project-id>.supabase.co
# VITE_SUPABASE_ANON_KEY=<anon-key>
#
# NOTE: VITE_* vars are baked in at Vite build time. For Docker, set them
# before `docker compose up` — docker-compose passes them as build args.
