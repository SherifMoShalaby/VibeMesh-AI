# ── AI engines — configure any subset; the app lists whatever is available ──

# Claude via your Claude Code login: nothing to configure here.
# Just have Claude Code installed and logged in (`claude` → /login).
# NOTE: Anthropic only permits this for personal/local use — a distributed
# product must use API keys (or get approval to offer Claude login).

# Claude via API key (https://console.anthropic.com)
# ANTHROPIC_API_KEY=sk-ant-...
# VIBESCAD_MODEL=claude-opus-4-8

# Kimi K2.6 via your Kimi Code subscription:
# easiest: log in once with the kimi CLI — the server reuses that login.
# Or create an API key in the Kimi Code console and set:
# KIMI_API_KEY=...
# KIMI_BASE_URL=https://api.kimi.com/coding
# KIMI_MODEL=kimi-for-coding

# Local LLM (Ollama or LM Studio, OpenAI-compatible).
# Ollama default below; LM Studio uses http://localhost:1234
# LOCAL_LLM_BASE_URL=http://localhost:11434

# PORT=5175
