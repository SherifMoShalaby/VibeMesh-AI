{
  "name": "vibemesh-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI text/image-to-CAD for 3D printing — plain-language prompts become parametric OpenSCAD, rendered in-browser via openscad-wasm with live parameter sliders and slicer-ready .3mf/.stl export. Local-first.",
  "license": "MIT",
  "author": "Sherif Mo. Shalaby <sherif2222222@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SherifMoShalaby/VibeMesh-AI.git"
  },
  "homepage": "https://github.com/SherifMoShalaby/VibeMesh-AI#readme",
  "bugs": {
    "url": "https://github.com/SherifMoShalaby/VibeMesh-AI/issues"
  },
  "keywords": [
    "openscad",
    "3d-printing",
    "cad",
    "text-to-cad",
    "ai",
    "parametric",
    "wasm",
    "react",
    "stl",
    "3mf"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c yellow,cyan \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "PORT=5175 node server/index.mjs",
    "dev:web": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "start": "NODE_ENV=production node server/index.mjs",
    "preview": "vite preview",
    "bench": "node bench/run.mjs",
    "bench:score": "node bench/score.mjs",
    "bench:interference": "node bench/interference.selftest.mjs",
    "bench:skills": "node bench/skills.selftest.mjs",
    "bench:retrieval": "node bench/retrieval.selftest.mjs",
    "bench:recall": "node bench/retrieval-recall.mjs",
    "bench:intent": "tsx bench/intent.selftest.ts",
    "bench:composition": "node bench/composition.selftest.mjs",
    "bench:compgraph": "node bench/composition-graph.selftest.mjs",
    "bench:hardware": "node bench/hardware.selftest.mjs",
    "bench:server": "node bench/server.selftest.mjs",
    "bench:ratelimit": "node bench/ratelimit.selftest.mjs",
    "bench:trace": "tsx bench/trace.selftest.mjs",
    "bench:silhouette": "node bench/silhouette.selftest.mjs",
    "bench:silhouette-live": "tsx bench/silhouette-live.selftest.mjs",
    "spike:registration": "tsx bench/registration-spike.mjs",
    "bench:clarify": "node bench/clarify.selftest.mjs",
    "bench:coilspring": "node bench/coilspring-verdict.mjs",
    "bench:gatelogic": "node bench/gate.selftest.mjs",
    "test:pack": "tsx bench/packplates.selftest.ts",
    "bench:selftests": "node bench/interference.selftest.mjs && node bench/skills.selftest.mjs && node bench/retrieval.selftest.mjs && node bench/retrieval-recall.mjs && tsx bench/intent.selftest.ts && node bench/composition.selftest.mjs && node bench/composition-graph.selftest.mjs && node bench/hardware.selftest.mjs && node bench/server.selftest.mjs && node bench/ratelimit.selftest.mjs && tsx bench/trace.selftest.mjs && node bench/silhouette.selftest.mjs && tsx bench/silhouette-live.selftest.mjs && node bench/clarify.selftest.mjs && node bench/gate.selftest.mjs",
    "bench:gate": "vitest run && npm run bench:selftests && node bench/gate.mjs",
    "bench:baseline": "node bench/gate.mjs --update-baseline"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.185",
    "@anthropic-ai/sdk": "^0.105.0",
    "@codemirror/lang-cpp": "^6.0.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@supabase/supabase-js": "^2.108.2",
    "@uiw/react-codemirror": "^4.25.10",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "fflate": "^0.8.3",
    "framer-motion": "^12.40.0",
    "openscad-wasm": "^0.0.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "three": "^0.184.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  }
}
