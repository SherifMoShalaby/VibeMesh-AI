{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npm run dev:*)",
      "Bash(npm run dev:server:*)",
      "Bash(npm run dev:web:*)",
      "Bash(npm run build:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run preview:*)",
      "Bash(node bench/run.mjs:*)",
      "Bash(node bench/score.mjs:*)",
      "Bash(node bench/compare.mjs:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)"
    ]
  }
}
